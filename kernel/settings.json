{
  "_comment": "Claude Code Starter Pack — restrictive baseline. Edit at your own risk; the deny rules and disableBypassPermissionsMode are the safety net. Add allow rules as you learn what you trust.",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit(*)",
      "Write(*)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(jq *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(node *)",
      "Bash(npm run*)",
      "Bash(npm test*)",
      "Bash(npm list*)",
      "Bash(npm ls*)",
      "Bash(npx *)",
      "Bash(python3 *)",
      "Bash(pip3 list*)",
      "Bash(pip3 show*)",
      "Bash(cd *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(date *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(~/.claude/scripts/list-env-keys.sh*)",
      "Bash(curl*)",
      "Bash(wget*)",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Task*",
      "Skill(*)"
    ],
    "deny": [
      "Bash(rm -r *)",
      "Bash(rm -R *)",
      "Bash(rm -rf *)",
      "Bash(rm -rR *)",
      "Bash(rm -fr *)",
      "Bash(rm -fR *)",
      "Bash(mv -f *)",
      "Bash(mv -f*)",
      "Bash(sudo *)",
      "Bash(chmod -R *)",
      "Bash(chmod 777 *)",
      "Bash(chmod 666 *)",
      "Bash(chmod +s *)",
      "Bash(chown *)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(dd of=*)",
      "Bash(eval *)",
      "Bash(launchctl *)",
      "Bash(export *)",
      "Bash(curl * | bash*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(git push --force*)",
      "Bash(git push *--force*)",
      "Bash(git push -f*)",
      "Bash(git push *-f *)",
      "Bash(git reset --hard*)",
      "Bash(git checkout -- *)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git branch -D*)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit -n *)",
      "Bash(git commit -a*)",
      "Bash(npm publish*)",
      "Bash(npm install --global*)",
      "Bash(npm install -g*)",
      "Bash(pkill *)",
      "Bash(killall *)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(halt*)",
      "Edit(~/.claude/settings*)",
      "Write(~/.claude/settings*)",
      "Edit(~/.bashrc)",
      "Write(~/.bashrc)",
      "Edit(~/.zshrc)",
      "Write(~/.zshrc)",
      "Edit(~/.zprofile)",
      "Write(~/.zprofile)",
      "Edit(~/.bash_profile)",
      "Write(~/.bash_profile)",
      "Edit(~/.ssh/**)",
      "Write(~/.ssh/**)",
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.kube/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.docker/config.json)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/Library/Keychains/**)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ],
    "ask": [
      "Bash(brew install*)",
      "Bash(brew uninstall*)",
      "Bash(brew upgrade*)",
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(npm install*)",
      "Bash(npm uninstall*)",
      "Bash(npm update*)",
      "Bash(ssh*)",
      "Bash(scp*)",
      "Bash(rsync*)",
      "Bash(docker*)",
      "Bash(kill *)",
      "Bash(rm *)",
      "Bash(git push*)",
      "Bash(git rebase*)",
      "Bash(git merge*)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/bash-safety-extended.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notes-research.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/inbox-processor.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1"
  },
  "alwaysThinkingEnabled": true
}
